# GCP Project Configuration
PROJECT_ID=skillbridge-rwanda
LOCATION=us-central1

# Vertex AI
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004

# Vector Search (if using Vertex AI Vector Search)
VECTOR_SEARCH_INDEX_ENDPOINT=
VECTOR_SEARCH_INDEX_ID=
VECTOR_SEARCH_DEPLOYED_INDEX_ID=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/skillbridge

# Firestore
FIRESTORE_COLLECTION=chat_sessions

# CORS
CORS_ORIGINS=["http://localhost:3000","https://skillbridge-rwanda.web.app"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
